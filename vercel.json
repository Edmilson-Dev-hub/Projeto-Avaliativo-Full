{
  "version": 2,
  "builds": [
    {
      "src": "Galaticos_Fitness_Back/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "Galaticos_Fitness_Front/front/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build/web" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "Galaticos_Fitness_Back/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "Galaticos_Fitness_Front/front/$1"
    }
  ]
}
